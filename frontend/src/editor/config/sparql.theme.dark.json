{
  "name": "SPARQL Nightfall",
  "type": "dark",
  "colors": {
    "editor.foreground": "#d8dee9",
    "editor.background": "#18181b",
    "editorGutter.background": "#1a1e24",
    "editorLineNumber.foreground": "#aaaaaa",
    "editorLineNumber.activeForeground": "#d8dee9",
    "editor.selectionBackground": "#2a3b5a",
    "editor.lineHighlightBackground": "#1c222a",
    "editorCursor.foreground": "#e5e9f0",
    "editorWhitespace.foreground": "#3c4048",
    "editorIndentGuide.activeBackground": "#444c56",
    "editor.selectionHighlightBorder": "#30363d"
  },
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "keyword": { "foreground": "#0d9488", "bold": true },
    "function": { "foreground": "#f87171", "bold": true },
    "variable": "#7dd3fc",
    "string": "#a3e635",
    "number": "#fca5a5",
    "comment": { "foreground": "#6b7280", "italic": true },
    "operator": "#e07a5f",
    "namespace": { "foreground": "#93e1d8", "italic": true }
  }
}
