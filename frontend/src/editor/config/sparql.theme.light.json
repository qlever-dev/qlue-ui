{
  "name": "SPARQL Custom Light Theme",
  "type": "light",
  "colors": {
    "editor.foreground": "#24292e",
    "editor.background": "#ffffff",
    "editorGutter.background": "#f5f5f5",
    "editor.selectionBackground": "#cce5ff",
    "editor.lineHighlightBackground": "#E8F2FF",
    "editorCursor.foreground": "#3C3836",
    "editorWhitespace.foreground": "#d1d5da",
    "editorIndentGuide.activeBackground": "#e1e4e8",
    "editor.selectionHighlightBorder": "#d0d7de"
  },
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "keyword": { "foreground": "#8F3F71", "bold": true },
    "function": { "foreground": "#CC241D", "bold": true },
    "variable": "#458588",
    "string": "#D79921",
    "number": "#005cc5",
    "comment": { "foreground": "#6a737d", "italic": true },
    "operator": "#B16286",
    "namespace": "#32302F"
  }
}
